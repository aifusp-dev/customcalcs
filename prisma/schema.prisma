// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CalculatorRole {
  OWNER
  EDITOR
  MEMBER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  googleId  String?  @unique
  createdAt DateTime @default(now())

  ownedCalculators Calculator[]       @relation("CalculatorOwner")
  memberships      CalculatorMember[]
  sales            Sale[]

  @@map("users")
}

model Calculator {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  ownerId          String
  ownerDisplayName String?
  accentColor      String   @default("#ffffff")
  createdAt        DateTime @default(now())

  owner     User               @relation("CalculatorOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  items     Item[]
  members   CalculatorMember[]
  sales     Sale[]
  discounts Discount[]

  discordWebhook DiscordWebhook?

  @@map("calculators")
}

model DiscordWebhook {
  id           String   @id @default(cuid())
  calculatorId String   @unique
  webhookUrl   String
  guildName    String?
  channelName  String?
  createdAt    DateTime @default(now())

  calculator Calculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)

  @@map("discord_webhooks")
}

model DiscordLinkToken {
  token       String   @id
  webhookUrl  String
  guildName   String?
  channelName String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@map("discord_link_tokens")
}

model CalculatorMember {
  id           String         @id @default(cuid())
  calculatorId String
  userId       String
  role         CalculatorRole @default(MEMBER)
  displayName  String?
  createdAt    DateTime       @default(now())

  calculator Calculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([calculatorId, userId])
  @@map("calculator_members")
}

model Item {
  id           String   @id @default(cuid())
  calculatorId String
  name         String
  price        Decimal  @db.Decimal(10, 2)
  imageUrl     String?
  stock        Int      @default(0)
  category     String?
  createdAt    DateTime @default(now())

  calculator Calculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)
  saleItems  SaleItem[]

  @@map("items")
}

model Sale {
  id                 String   @id @default(cuid())
  calculatorId       String
  userId             String
  subtotal           Decimal  @db.Decimal(10, 2)
  discountName       String?
  discountPercentage Decimal? @db.Decimal(5, 2)
  total              Decimal  @db.Decimal(10, 2)
  createdAt          DateTime @default(now())

  calculator Calculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      SaleItem[]

  @@map("sales")
}

model Discount {
  id           String   @id @default(cuid())
  calculatorId String
  name         String
  percentage   Decimal  @db.Decimal(5, 2)
  createdAt    DateTime @default(now())

  calculator Calculator @relation(fields: [calculatorId], references: [id], onDelete: Cascade)

  @@map("discounts")
}

model SaleItem {
  id       String  @id @default(cuid())
  saleId   String
  itemId   String?
  name     String
  price    Decimal @db.Decimal(10, 2)
  quantity Int

  sale Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  item Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@map("sale_items")
}
